.DS_Store

# Claude Code per-user state — keep slash commands tracked
.claude/settings.local.json
.claude/.local/

# Python
__pycache__/
*.py[cod]

# 本地运行产物（可选：若希望把 archive 一并提交备份，可删除下行）
archive/

# 研报工作区（各次运行生成的 JSON / HTML 等）
workspace/

# 本地演示 Web UI（不提交到 skill 包）
DEMO WEB UI/

# 若本地重新打包 skill，不想提交二进制
*.skill
