  "default_cleanup_targets": [
    "companyfacts_*.json",
    "*_10k.html",
    "tmp*",
    "*.tmp",
    "debug_*"
  ],
  "failure_caps": {
    "subagent_retry_same_prompt": 2,
    "phase_5_5_to_phase_5_data_validation": 2,
    "phase_5_7_red_team_to_phase_5": 1,
    "phase_incident_postcheck_flagged_retry": 0
  },
  "subagent_timeouts_seconds": {
    "research": 600,
    "qc": 180
  }
